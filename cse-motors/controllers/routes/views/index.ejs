<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<header>
    <%- include("partials/header") %>
    <%- include("partials/navigation") %>
</header>

<main>

<h1 class="page-title">Welcome to CSE Motors</h1>

<section class="hero">

    <img src="/images/vehicles/delorean.jpg" alt="Delorean Car">

    <div class="hero-text">
        <h2>DMC Delorean</h2>

        <ul>
            <li>3 Cup holders</li>
            <li>Superman doors</li>
            <li>Fuzzy dice</li>
        </ul>

        <button class="cta">Own Today</button>
    </div>

</section>


<section class="home-sections">

    <div class="reviews">
        <h2>DMC Delorean Reviews</h2>

        <ul>
            <li>"So fast its almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'm feeling McFly!" (5/5)</li>
            <li>"The most futuristic ride of our day." (4.5/5)</li>
        </ul>
    </div>


    <div class="upgrades">

        <h2>Delorean Upgrades</h2>

        <div class="upgrade-grid">

            <div>
                <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
                <p>Flux Capacitor</p>
            </div>

            <div>
                <img src="/images/upgrades/flame.jpg" alt="Flame Decals">
                <p>Flame Decals</p>
            </div>

            <div>
                <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers">
                <p>Bumper Stickers</p>
            </div>

            <div>
                <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps">
                <p>Hub Caps</p>
            </div>

        </div>

    </div>

</section>

</main>

<footer>
    <%- include("partials/footer") %>
</footer>

</body>
</html>